# Postgres (required)
# Default matches docker-compose.yml (host port 5433)
DATABASE_URL=postgres://postgres:postgres@127.0.0.1:5433/agent_commerce

PORT=3210

# When set, POST /v1/tenants requires: Authorization: Bearer <this exact string>
# Use the secret only — do not put the word "Bearer" inside this value.
BOOTSTRAP_ADMIN_TOKEN=
#
# All other /v1/* routes (including GET /v1/paperclip/ping) need the tenant
# apiKey returned in the JSON body of POST /v1/tenants — not BOOTSTRAP_ADMIN_TOKEN.
